#include "ld_unittests.xcconfig"

GCC_PREPROCESSOR_DEFINITIONS = $(inherited) BUILDING_CACHE_BUILDER=1 BUILDING_APP_CACHE_UTIL=1

LD_RUNPATH_SEARCH_PATHS = @loader_path/../Frameworks

